{
  "cli": {
    "version": ">= 18.0.1",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development"
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "channel": "main"
    },
    "production": {
      "autoIncrement": true,
      "channel": "production"
    }
  },
  "updates": {
    "development": {
      "branch": "development"
    },
    "preview": {
      "branch": "main"
    },
    "production": {
      "branch": "production"
    }
  },
  "submit": {
    "production": {}
  }
}